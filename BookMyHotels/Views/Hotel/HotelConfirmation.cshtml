@using Data.GetMeRoom.Models.PreBook
@using Data.GetMeRoom.Models.Book
@model Data.GetMeRoom.Models.Book.BookRS_V1
@{
    ViewBag.Title = "HotelConfirmation";
    Layout = "~/Views/Shared/_result_Layout.cshtml";
}
@if (Model.errorCode == 0 && Model.errorMessage == "" && Model.bookingStatus == "Confirmed")
{
    int a = 1;
    PreBookRS_V1 _PreBook = (PreBookRS_V1)Session["PreBookRS"];
    BookRQ_V1 bookRQ = (BookRQ_V1)Session["bookRQ"];
    var totalPrice = _PreBook?.Hotel?.Rate?.Room?.Sum(x => x.GrossPrice);
    <main id="content" class="bg-gray space-2">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 col-xl-9">
                    <div class="mb-5 shadow-soft bg-white rounded-sm">
                        <div class="py-6 px-5 border-bottom">
                            <div class="flex-horizontal-center">
                                <div class="height-50 width-50 flex-shrink-0 flex-content-center bg-primary rounded-circle" style="background: #43ac10 !important;">
                                    <i class="fa fa-check text-white font-size-24"></i>
                                </div>
                                <div class="ml-3">
                                    <h3 class="font-size-18 font-weight-bold text-dark mb-0 text-lh-sm">
                                        Thank You. Your Booking Order is @Model.bookingStatus Now.
                                    </h3>
                                    <p class="mb-0">A confirmation email has been sent to your provided email address.</p>
                                </div>
                            </div>
                        </div>
                        <div class="pt-4 pb-5 px-5 border-bottom">
                            <h5 id="scroll-description" class="font-size-21 font-weight-bold text-dark mb-2">
                                Traveler Information
                            </h5>
                            <!-- Fact List -->
                            <ul class="list-unstyled font-size-1 mb-0 font-size-16">
                                <li class="d-flex justify-content-between py-2">
                                    <span class="font-weight-medium">Booking number</span>
                                    <span class="text-secondary text-right">@Model.bookingId-@Model.providerConfirmationNumber</span>
                                </li>
                                <li class="d-flex justify-content-between py-2">
                                    <span class="font-weight-medium">First name</span>
                                    <span class="text-secondary text-right">@bookRQ.room_details.FirstOrDefault().passengers.FirstOrDefault().first_name</span>
                                </li>
                                <li class="d-flex justify-content-between py-2">
                                    <span class="font-weight-medium">Last name</span>
                                    <span class="text-secondary text-right">@bookRQ.room_details.FirstOrDefault().passengers.FirstOrDefault().last_name</span>
                                </li>
                                <li class="d-flex justify-content-between py-2">
                                    <span class="font-weight-medium">E-mail address</span>
                                    <span class="text-secondary text-right">@bookRQ.room_details.FirstOrDefault().passengers.FirstOrDefault().email_id</span>
                                </li>
                                <li class="d-flex justify-content-between py-2">
                                    <span class="font-weight-medium">Street Address and number</span>
                                    <span class="text-secondary text-right">@bookRQ.passenger_address.address</span>
                                </li>
                                <li class="d-flex justify-content-between py-2">
                                    <span class="font-weight-medium">Town / City</span>
                                    <span class="text-secondary text-right">@bookRQ.passenger_address.city</span>
                                </li>
                                <li class="d-flex justify-content-between py-2">
                                    <span class="font-weight-medium">State</span>
                                    <span class="text-secondary text-right">@bookRQ.passenger_address.country_code</span>
                                </li>
                                <li class="d-flex justify-content-between py-2">
                                    <span class="font-weight-medium">Zip</span>
                                    <span class="text-secondary text-right">@bookRQ.passenger_address.zip_code</span>
                                </li>
                            </ul>
                            <!-- End Fact List -->
                        </div>
                        <div class="product-item__outer w-100">
                            <div class="row">
                                <div style="width:100%; height:auto; float:left;">
                                    <div style="margin-top:20px; margin-left:50px !important;">
                                        <h4 class="font-size-23 font-weight-bold mb-1">@_PreBook.Hotel.Name</h4>
                                        <div class=" font-size-10 letter-spacing-2">
                                            <span class="d-block green-lighter ">
                                                @{
                                                    string[] hotelstar = _PreBook.Hotel.Star.Split('.');
                                                    for (int i = 0; i < Convert.ToInt32(hotelstar[0]); i++)
                                                    {
                                                        <small>
                                                            <img src="~/Content/img/star.png" />
                                                        </small>
                                                    }
                                                    if (hotelstar.Length > 1)
                                                    {
                                                        <small>
                                                            <img src="~/Content/img/halfstar.png" />
                                                        </small>
                                                    }
                                                }
                                            </span>
                                        </div>
                                        <div class="d-block d-md-flex flex-horizontal-center font-size-14 text-gray-1" style="margin-top:10px;">
                                            <img src="~/images/location-icon.png" style="max-width:15px; margin-right:6px;" class="mCS_img_loaded"> @_PreBook.Hotel.Address, @_PreBook.Hotel.City, @_PreBook.Hotel.Country
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-5 col-lg-5 col-xl-3dot5">
                                    <div class="pt-5 pb-md-5 pl-4 pr-4 pl-md-5 pr-md-2 pr-xl-2">
                                        <div class="product-item__header mt-2 mt-md-0">
                                            <div class="position-relative">
                                                <img class="img-fluid rounded-sm" src="@_PreBook.Hotel.Image" alt="@_PreBook.Hotel.Name">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col col-md-7 col-lg-7 col-xl-5 flex-horizontal-center pl-xl-0">
                                    @foreach (var room in @_PreBook.Hotel.Rate.Room)
                                    {
                                        string child = string.Empty;
                                        if (room.Child != 0)
                                        {
                                            child = ", " + room.Child.ToString() + " Child";
                                        }


                                        <div class="w-100 position-relative m-4 m-md-0">
                                            <a href="#" class="mb-2 d-inline-block">
                                                <span class="font-weight-bold font-size-17 text-dark text-dark">
                                                    Room @a: @room.RoomType - @room.Adult Adults @child
                                                </span>
                                            </a>
                                            <div class="mt-1 pt-2">
                                                <div class="d-flex mb-1">
                                                    <div class="ml-0">
                                                        <ul class="list-unstyled mb-0">
                                                            <li class="media mb-3 text-gray-1">
                                                                <small class="mr-2">
                                                                    <small class="fa fa-hotel font-size-17 text-primary"></small>
                                                                </small>
                                                                <div class="media-body font-size-1 ml-1">
                                                                    @room.BoardBasis
                                                                </div>
                                                            </li>
                                                            @*@if (room.Beds != null)
                                                            {
                                                                <li class="media mb-3 text-gray-1">
                                                                    <small class="mr-2">
                                                                        <small class="fa fa-child font-size-17 text-primary"></small>
                                                                    </small>
                                                                    <div class="media-body font-size-1 ml-1">
                                                                        @room?.Beds?.FirstOrDefault()?.Count @room?.Beds?.FirstOrDefault()?.Type
                                                                    </div>
                                                                </li>
                                                            }*@
                                                        </ul>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        a++;
                                    }
                                    </div>


                                    <div class="col col-xl-3dot5 align-self-center py-4 py-xl-0 border-top border-xl-top-0">
                                        <div class="flex-content-center border-xl-left  ml-4 ml-xl-0 justify-content-start justify-content-xl-center">
                                            <div class="text-center my-xl-1">
                                                <div class="mb-2 pb-1" style="padding: 10px !important;">
                                                    <span class="font-size-14" style="font-weight:500;">
                                                        <div class="height-50 width-50 flex-shrink-0 flex-content-center bg-primary rounded-circle" style="background: #43ac10 !important; margin: 0 auto;">
                                                            <i class="fa fa-check text-white font-size-24"></i>
                                                        </div>
                                                        Paid Amount
                                                    </span>
                                                    <br>
                                                    <span class="font-weight-bold font-size-22 ml-1"> @_PreBook.ResponseInfo.Currency @totalPrice </span> for<br>
                                                    <span class="media-body font-size-1 ml-1"> @_PreBook.ResponseInfo.TotalRooms room x @_PreBook.ResponseInfo.Nights nights</span><br>
                                                    <span class="media-body font-size-1 ml-1"> from  @_PreBook.ResponseInfo.CheckIn.ToString("dd MMM yyyy") - @_PreBook.ResponseInfo.CheckOut.ToString("dd MMM yyyy")</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <div class="pt-4 pb-5 px-5 border-bottom">
                            <h5 id="scroll-description" class="font-size-18  text-dark mb-3" style="font-weight:400;border-bottom:1px solid #e7eaf3 ; padding-bottom:5px; ">
                                If there is any query, Contact our Booking Expert<br>
                                <span style="font-size:15px;">Call for more information to discuss your unique requirements if any</span>
                            </h5>
                            <p class="">
                            </p><h4 class="h6 mb-4 font-weight-bold"></h4>
                            <a href="tel:0203 582 9884">
                                <div class="d-flex align-items-center" style="width:50%; float:left;">
                                    <div class="mr-4">
                                        <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="40px" height="40px">
                                            <path fill-rule="evenodd" class="fill-primary" d="M36.093,16.717 L33.133,16.717 L30.864,19.693 C30.717,19.886 30.487,20.000 30.244,20.000 C30.244,20.000 30.243,20.000 30.243,20.000 C30.000,20.000 29.771,19.888 29.623,19.695 L27.335,16.717 L24.372,16.717 C22.218,16.717 20.465,14.965 20.465,12.811 L20.465,3.907 C20.465,1.753 22.218,0.001 24.372,0.001 L36.093,0.001 C38.247,0.001 40.000,1.753 40.000,3.907 L40.000,12.811 C40.000,14.965 38.247,16.717 36.093,16.717 ZM38.437,3.907 C38.437,2.615 37.386,1.563 36.093,1.563 L24.372,1.563 C23.080,1.563 22.028,2.615 22.028,3.907 L22.028,12.811 C22.028,14.103 23.080,15.155 24.372,15.155 L27.721,15.155 C27.964,15.155 28.193,15.268 28.340,15.460 L30.240,17.934 L32.124,15.462 C32.272,15.269 32.502,15.155 32.746,15.155 L36.093,15.155 C37.386,15.155 38.437,14.103 38.437,12.811 L38.437,12.811 L38.437,3.907 ZM31.014,8.429 L31.014,9.647 C31.014,10.078 30.664,10.428 30.232,10.428 C29.801,10.428 29.451,10.078 29.451,9.647 L29.451,8.239 C29.451,7.618 29.876,7.089 30.485,6.953 C31.041,6.829 31.416,6.323 31.376,5.752 C31.337,5.186 30.881,4.730 30.316,4.691 C29.992,4.669 29.685,4.777 29.451,4.996 C29.216,5.216 29.086,5.514 29.086,5.834 C29.086,6.266 28.736,6.616 28.305,6.616 C27.873,6.616 27.523,6.266 27.523,5.834 C27.523,5.087 27.837,4.365 28.384,3.854 C28.939,3.336 29.663,3.081 30.423,3.132 C31.763,3.225 32.843,4.304 32.935,5.644 C33.024,6.927 32.225,8.068 31.014,8.429 ZM30.233,11.646 C30.438,11.646 30.640,11.729 30.785,11.874 C30.930,12.020 31.014,12.221 31.014,12.427 C31.014,12.633 30.930,12.834 30.785,12.980 C30.640,13.125 30.438,13.209 30.233,13.209 C30.027,13.209 29.825,13.125 29.680,12.980 C29.535,12.834 29.451,12.633 29.451,12.427 C29.451,12.221 29.535,12.020 29.680,11.874 C29.825,11.729 30.027,11.646 30.233,11.646 ZM14.440,16.019 L23.973,25.550 L24.760,24.764 C24.760,24.764 24.760,24.764 24.760,24.764 C24.760,24.764 24.761,24.763 24.761,24.763 L26.731,22.794 C27.574,21.951 28.695,21.487 29.8