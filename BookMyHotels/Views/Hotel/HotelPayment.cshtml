                                            <ul class="list-unstyled font-size-1 mb-0 font-size-16">
                                                <li class="d-flex justify-content-between">
                                                    <span class="font-weight-medium">Subtotal</span>
                                                    <span class="text-secondary">@Currency @(totalPrice - totalTax)</span>
                                                </li>

                                                <li class="d-flex justify-content-between">
                                                    <span class="font-weight-medium">Tax</span>
                                                    <span class="text-secondary">@Currency @totalTax</span>
                                                </li>

                                                <li class="d-flex justify-content-between">
                                                    <span class="font-weight-medium">Local Tax</span>
                                                    <span class="text-secondary">0 %</span>
                                                </li>

                                                <li class="d-flex justify-content-between font-size-17 font-weight-bold">
                                                    <span class="font-weight-bold">Pay Amount</span>
                                                    <span class="">@Currency @(totalPrice)</span>
                                                </li>
                                            </ul>
                                            <!-- End Fact List -->
                                        </div>
                                    </div>
                                </div>
                                <!-- End Card -->
                            </div>
                            <!-- End Basics Accordion -->
