@using Data.GetMeRoom.Models.PreBook
@model PreBookRS_V1
@using NLog
@{
    
    ViewBag.Title = "HotelPayment";
    Layout = "~/Views/Shared/_result_Layout.cshtml";
    var cancillationText = string.Empty;
    Logger logger = LogManager.GetCurrentClassLogger();
}
<title>GetmeRooms: Secure Payment</title>
<link href="~/Content/css/hotel-payment.css" rel="stylesheet" />
<style type="text/css">
    small {
        color: #5a748e !important;
/*        font-size: 15px !important;*/
    }

    ul {
/*        font-size: 13px !important;*/
        line-height: 25px !important;
    }

    li {
/*        color: #5a748e !important;*/
    }
</style>

<main id="content" class="hotelpaymentmt">
    <div class="container">
        <div class="row">


            @if (Model?.ResponseInfo != null && Model.ResponseInfo.IsBookable && Model?.Hotel != null && (Model?.ResponseInfo?.ErrorCode == "" || Model?.ResponseInfo?.ErrorCode == "0"))
            {
                try
                {
                    var ResponseInfo = Model.ResponseInfo;
                    Hotel hotel = Model?.Hotel;
                    List<Room> rooms = Model?.Hotel?.Rate?.Room;
                    Policy policy = rooms?.FirstOrDefault()?.Policies?.Policy?.Where(x => x.EstimatedValue == 0).FirstOrDefault();
                    string freeCancilation = policy == null ? string.Empty : policy.End;//.ToString("dd-MM-yyyy hh:mm");
                    double totalPrice;
                    try
                    {
                        totalPrice = rooms.Sum(x => x.DailyRates.Sum(y => y.GrossPrice));
                    }
                    catch (Exception ex)
                    {
                        logger.Error("Error on HotelPayment.cshtml getting GrossPrice: " + ex.Message);
                        totalPrice = Convert.ToDouble(ResponseInfo.BookingToken.Split('#')[3]) * Convert.ToDouble(ResponseInfo.Nights);
                    }
                    //var rooms.Sum(x => x.DailyRates.Sum(y => y.GrossPrice));
                    double totalTax = 0;
                    try
                    {
                        totalTax = rooms.Sum(x => x.Taxes.Sum(y => y.GrossPrice));
                    }
                    catch (Exception ex)
                    {
                        logger.Error("Error on HotelPayment.cshtml calculate totalTax : " + ex.Message);
                    }

                    var Currency = "";

                    if (Data.GetMeRoom.GlobalConstant.ConfigVariables.SITEROOTPATH.Contains("bookmyhotels.co.in"))
                    {
                        Currency = "INR";
                    }
                    else
                    {
                        Currency = ResponseInfo.Currency;
                    }

                    <div class="col-lg-4 col-xl-4  col-sm-push-8" style="margin-bottom:15px;">


                        <div class="card mb-5">
                            <div class="border-bottom">
                                <a href="#" class="d-block">
                                    <img class="img-fluid" src="@hotel.Image" alt="@hotel.Name" style="width: 100%; padding: 15px; border-radius: 32px;">
                                </a>
                                <div class="px-3">
                                    <a href="#" class="text-dark font-weight-bold pr-xl-1" id="stickyBlockStartPoint1">@hotel.Name</a>
                                    <div class="my-1 flex-horizontal-center text-gray-1">
                                        <img src="~/images/location-icon.png" style="max-width:15px; margin-right:6px;" class="mCS_img_loaded">  @hotel.Address, @hotel.Country
                                    </div>


                                    @for (int i = 0; i < rooms?.Count; i++)
                                    {
                                        <p class="text-dark font-weight-bold pr-xl-1 text-gray-1" style="display:none;">Room @(Convert.ToInt32(i) + 1): @rooms[i].RoomType - @rooms[i].Adult Adults</p>
                                    }


                                    @*<p><span class="font-size-16" style="color: #2f7000 !important;"><i class="fa fa-check"></i> Free Cancellation before @freeCancilation </span></p>*@

                                    @if (!string.IsNullOrEmpty(freeCancilation))
                                    {
                                        <p><span class="font-size-16" style="color: #2f7000 !important;"><i class="fa fa-check"></i> Free Cancellation before @freeCancilation </span></p>
                                    }
                                </div>
                            </div>
                            <!-- Basics Accordion -->
                            <div id="basicsAccordion">
                                <!-- Card -->
                                <div class="card rounded-0 border-top-0 border-left-0 border-right-0">
                                    <div class="card-header card-collapse bg-transparent border-1" id="basicsHeadingOne">
                                        <h5 class="mb-0">
                                            <button type="button" class="btn btn-link border-0 btn-block d-flex justify-content-between card-btn py-3 px-3 font-size-17 font-weight-bold text-dark"
                                                    data-toggle="collapse"
                                                    data-target="#basicsCollapseOne"
                                                    aria-expanded="true"
                                                    aria-controls="basicsCollapseOne">
                                                Booking Detail

                                                <span class="card-btn-arrow font-size-14 text-dark">
                                                    <i class="fas fa-chevron-down"></i>
                                                </span>
                                            </button>
                                        </h5>
                                    </div>
                                    <div id="basicsCollapseOne" class="collapse show"
                                         aria-labelledby="basicsHeadingOne"
                                         data-parent="#basicsAccordion">
                                        <div class="card-body px-3 pt-0">
                                            <!-- Fact List -->
                                            <ul class="list-unstyled font-size-1 mb-0 font-size-16 mt-3" style="padding-left: 0px !important;">
                                                <li class="d-flex justify-content-between ">
                                                    <span class="font-weight-medium">
                                                        @*@ResponseInfo.CheckIn.ToString("dd MMM yyyy") - @ResponseInfo.CheckOut.ToString("dd MMM yyyy")*@
                                                        <span class="text-gray-1 font-weight-normal">@ResponseInfo.TotalRooms room x @ResponseInfo.Nights nights</span>

                                                    </span>
                                                    @*<span class="text-secondary"><a href="#" class="text-underline">Edit</a></span>*@
                                                </li>
                                                <li class="d-flex justify-content-between ">
                                                    <span class="font-weight-medium">Check in</span>
                                                    <span class="text-secondary"> @ResponseInfo.CheckIn.ToString("dd MMM yyyy")</span>
                                                    @*05 August 2021*@
                                                </li>

                                                <li class="d-flex justify-content-between ">
                                                    <span class="font-weight-medium">Check out</span>
                                                    <span class="text-secondary">@ResponseInfo.CheckOut.ToString("dd MMM yyyy") </span>
                                                </li>



                                                <li class="d-flex justify-content-between py-2" style="display:none;padding:0px !important;">
                                                    @if (ResponseInfo.TotalAdult == 1)
                                                    {
                                                        <span class="font-weight-medium" style="display:none;">Adult</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="font-weight-medium" style="display:none;">Adult (s)</span>
                                                    }
                                                    <span class="text-secondary" style="display:none;">@ResponseInfo.TotalAdult</span>
                                                </li>

                                                @if (ResponseInfo.TotalChild > 0)
                                                {

                                                    <li class="d-flex justify-content-between py-2" style="display:none; padding:0px !important;">
                                                        @if (ResponseInfo.TotalChild == 1)
                                                        {
                                                            <span class="font-weight-medium" style="display:none;">Child</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="font-weight-medium" style="display:none;">Child (s)</span>
                                                        }
                                                        <span class="text-secondary" style="display:none;">@ResponseInfo.TotalChild   </span>
                                                    </li>
                                                }
                                                @*<li class="d-flex justify-content-between py-2" style="display:none !important;">
                                                <span class="font-weight-medium">Infant (s)</span>
                                                <span class="text-secondary">2</span>
                                            </li>*@
                                            </ul>
                                            <!-- End Fact List -->
                                        </div>
                                    </div>
                                </div>
                                <!-- End Card -->
                                <!-- Card -->
                                <div class="card rounded-0 border-top-0 border-left-0 border-right-0">
                                    <div class="card-header card-collapse bg-transparent border-1" id="basicsHeadingFour">
                                        <h5 class="mb-0">
                                            <button type="button" class="btn btn-link border-0 btn-block d-flex justify-content-between card-btn py-3 px-3 font-size-17 font-weight-bold text-dark"
