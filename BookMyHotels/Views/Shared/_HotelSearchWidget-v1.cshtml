<script type="text/javascript">

    $(function () {
        $("#location").autocomplete({
            source: function (request, response) {
                $.getJSON("/Suggest/autosuggest", { location: $('#location').val() },
                    response);
            },
            dataType: "json",
            type: "POST",
            contentType: "application/json; charset=utf-8",
            minLength: 3,
            select: function (event, ui) {
                $("#location").val(ui.item.PropertyName);
                $("#hdnlocation").val(ui.item.Code);
                event.preventDefault();
            }
        }).autocomplete("instance")._renderItem = function (ul, item) {
                return $("<li></li>").addClass("airport-bg")
                .append(item.RawString)
                .appendTo(ul);
            };
    });


    

      $(document).ready(function () {
        var roomInfo = '@roomInfo';
        var destination = '@destination';
        var destCode = '@destCode';
        var daterange = '@daterange';
        var totalrooms = '@totalrooms';
        if (destination != '' && destCode != '' && roomInfo != '' && totalrooms != '') {
            SetSearchVariables(destination, destCode, daterange, roomInfo, totalrooms);
          }


    });
</script>






