<script type="text/javascript">
    $(function () {
        $("#location").autocomplete({
            source: function (request, response) {
                $.ajax({
                    url: 'Home/getLocation',
                    //url: '/Home/GetLocation',
                    data: "{ location: '" + request.term + "'}",
                    dataType: "json",
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    success: function (data) {
                        response($.map(data, function (item) {
                            var text = item.Name + ', ' + item.CountryName;
                            var OthInfo = item.Code + ':' + item.CountryCode + ':' + item.Type;
                            return { label: text, value: OthInfo };
                        }))
                    },
                    error: function (response) {
                        alert(response.responseText);
                    },
                    failure: function (response) {
                        alert(response.responseText);
                    }
                });
            },
            select: function (e, i) {
                $("#location").val(i.item.label);
                $("#hdnlocation").val(i.item.value);
                return false;
            },
            minLength: 3
        });
    });
</script>


