@using Data.GetMeRoom.Models.GetRoomResponse;
@model List<Data.GetMeRoom.Models.GetRoomResponse.AdditionalCharges>

   

<div class="modal-dialog">

    <!-- Modal content-->
    <div class="modal-content">
        <div class="modal-header">

            <h4 class="modal-title">Additional Charges</h4>
            <button type="button" class="close" data-dismiss="modal">&times;</button>
        </div>
        <div class="modal-body">
            @if (Model?.Count > 0)
            {
                @*foreach (AdditionalCharges item in Model)
            {
                string freq = string.IsNullOrEmpty(item.Frequency) || item.Frequency.Trim() == "Unknown" ? string.Empty : item.Frequency;
                string Unit = string.IsNullOrEmpty(item.Unit) || item.Unit.Trim() == "Unknown" ? string.Empty : item.Unit;
                <p style="color:#3b444f;font-size:15px; ">Type: @item.Type @item.Currency @item.Amount -  @freq @Unit</p>
            }*@

                foreach (AdditionalCharges item in Model)
                {
                    string freq = string.IsNullOrEmpty(item.Frequency) || item.Frequency.Trim() == "Unknown" ? string.Empty : item.Frequency;
                    string Unit = string.IsNullOrEmpty(item.Unit) || item.Unit.Trim() == "Unknown" ? string.Empty : item.Unit;
                    <p style="color:#3b444f;font-size:15px; ">@item.Description @item.Amount @item.Currency @Unit @freq</p>
                }

            }
            else
            {
                <p style="color:#3b444f;font-size:15px; ">Additioanl charges not available</p>
            }

        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
        </div>
    </div>

</div>
