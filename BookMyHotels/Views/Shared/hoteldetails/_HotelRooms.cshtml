                                                <span style="position:absolute;float: right;right: 45px; color:#fff;">@ProviderNum</span>


                                                @*<br />   <span style="color:#23a101;font-weight: 400;">Free Cancellation till check in</span>*@

                                            </span>




                                            <div class="">
                                                <div class="d-flex mb-1">
                                                    @*@Html.Raw(Room.RoomDesc)*@
