            @using (Html.BeginForm("HotelPayment", "Hotel", FormMethod.Post, new { id = "DetailForm" }))
            {
                @Html.Hidden("Token", "", new { id = "Token" });
                @Html.Hidden("RateCode", "", new { id = "RateCode" });
                @Html.Hidden("RateId", "", new { id = "RateId" });
                @Html.Hidden("RoomId", "", new { id = "RoomId" });
                @Html.Hidden("HotelCode", Model.Rates.FirstOrDefault().Room.FirstOrDefault().ProviderHotelCode, new { id = "HotelCode" });

                @Html.AntiForgeryToken()
