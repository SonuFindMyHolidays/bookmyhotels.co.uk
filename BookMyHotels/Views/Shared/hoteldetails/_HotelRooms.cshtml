                {
                    var totalPrice = rate.Room.Sum(x => x.GrossPrice);
                    int i = 0;
                    int room = 0;
                    <div class="card border-co border-0lor-7 mb-5 overflow-hidden filteroom" data-refund="@rate.Room[0].IsRefundable" data-brb="@rate.Room[0].BoardBasis" style="border:1px solid #ccc; border-radius:0px;">
                        <div class="product-item__outer w-100">

                            @foreach (var _room in rate.Room)
                            {
                                int ProviderNum = _room.ProviderName == "Nuitee" ? 80 : _room.ProviderName == "Restel" ? 75 : 86;
                                room = room + 1;
                                string htmlimage = string.Empty;

                                var totalPaxes = _room.Adult > 1 ? _room.Adult + " Adults" : _room.Adult + " Adult";
                                if (_room.Child > 0)
                                {
                                    totalPaxes = totalPaxes + " + " + (_room.Child > 1 ? _room.Child + " Children" : _room.Child + " Child");
                                }

                                try
                                {
                                    var images = _room.Images?.Where(x => x.Size == "Standard").ToList();
                                    if (images != null)
                                    {
                                        Random rand = new Random();
                                        var image = images[rand.Next(images.Count)];
                                        htmlimage = "<img class='img-fluid rounded-sm' src='" + @image.Url + "' alt='" + @image.Size + "'>";
                                    }
                                }
                                catch (Exception)
                                {
                                    htmlimage = "<img class='img-fluid rounded-sm' src='~/../../Content/img/noImage.jpg' style='width:auto;' alt='No Image Available'>";
                                }
                                <!--Room Type 1-->
                                <div class="row">

                                    <div class=" " style="border-bottom:1px solid #ccc;display:block; border:12px solid #003580; width:1%; margin-right:20px;">

                                        <div class="triangle-right"></div>

                                    </div>

                                    <div class="col col-md-7 col-lg-7 col-xl-5 flex-horizontal-center pl-xl-0" style="border-right:1px solid #ccc;border-bottom:1px solid #ccc;">
                                        <div class="w-100 position-relative m-4 m-md-0">
