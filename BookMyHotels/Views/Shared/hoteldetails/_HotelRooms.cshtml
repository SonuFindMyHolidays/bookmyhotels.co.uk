                                                        }
                                                    </span>
                                                </div>
                                            </div>





                                        </div>
                                    </div>

                                    @if (i == 0)
                                    {
                                        <!--For Desktop Device Price Div Code Begin-->
                                        <div class="col col-xl-3dot5 align-self-center py-4 py-xl-0 border-top border-xl-top-0 desk_dis_block" style="">
                                            <div class="flex-content-center  py-xl-5 ml-4 ml-xl-0 justify-content-start justify-content-xl-center" style="padding-bottom: 0rem !important; padding-top: 0rem !important; ">
                                                <div class="text-center my-xl-1">
                                                    <div class="mb-0 pb-0">
                                                        <span>@TotalNights night for @noofrooms Room</span><br />

                                                        <span class="font-weight-bold font-size-25 ml-1" style="font-weight: 900; color: #0071c2; font-size: 15px !important; "> @currency <span style="font-size: 20px; font-weight: bold; color: #0071c2;">@totalPrice</span> </span>

                                                    </div>
                                                    <a data-ratecode="@rate.RateCode" data-token="@rate.Token" data-RateId="@_room.RateId" data-RoomId="@_room.RoomId" class="selectroom btn btn-primary mt-2"  data-toggle="modal" data-target="#myModal">Select Room <i class="fa fa-angle-right" style="font-weight:bold;"></i> </a>
                                                </div>
                                            </div>
                                        </div>
                                        <!--For Desktop Device Price Div Code End-->
