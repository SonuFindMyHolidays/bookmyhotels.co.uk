                                    }
                                </div>

                            }
                        </div>


                        <!--For Mobile Device Price Div Code Begin-->
                        <div class="mobile_dis_block" style="width:100%; float:left; height:auto; border-top:1px solid #ccc; background-color:#f2f2f2; ">

                            <div class=" align-self-center py-4 py-xl-0 border-top border-xl-top-0" style="">
                                <div class="  py-xl-5  ml-xl-0 justify-content-start justify-content-xl-center">
                                    <div class="text-center ">
                                        <div class="mb-2 pb-1" style="text-align:center !important;  ">
                                            <span>@TotalNights night for @noofrooms Room</span><br />

                                            <span class="font-weight-bold font-size-25 ml-1" style="font-weight: 900; color:#003580;"> @currency <span style="font-size:40px; font-weight:bold; color:#003580;">@totalPrice</span></span>

                                        </div>
                                        <a data-ratecode="@rate.RateCode" data-token="@rate.Token" data-RateId="@rate.Room[0].RateId" data-data-RoomId="@rate.Room[0].RoomId" class="selectroom btn btn-outline-primary border-radius-3 border-width-2 px-4 font-weight-bold min-width-200 py-2 text-lh-lg" style="font-weight: bold !important; text-transform: uppercase !important;background-color:#ff9100 !important; border:1px solid #003580 !important; color:#fff;" data-toggle="modal" data-target="#myModal">Reserve</a>
                                    </div>
                                </div>
                            </div>

                        </div>

                    </div>


                }
            }


        </div>


        <!-- Additional Charges -->

        @*<div class="modal fade" id="cancellation" role="dialog">

            </div>*@
        <!-- Loader content-->
        <div class="modal fade" id="myModal01" role="dialog">

            <div id="additional">


            </div>

            <div class="modal-dialog" style="visibility:hidden">
                <!-- Modal content-->
                <div class="modal-content">


                </div>
            </div>
        </div>

        <div class="modal fade" id="myModal" role="dialog">
            <div class="modal-dialog" style="max-width: 300px !important;">
                <!-- Modal content-->
                <div class="modal-content">

                    <div class="modal-body" style="padding: 0rem !important;">

                        <p style="        background-color: #fff;"><img src="../content/img/loader.gif" style="max-width:300px;" /></p>
                        <p style="color:#555; font-size:20px;background-color: #fff; padding:0px; text-align:center;margin-bottom: 0rem; margin-top:-80px;">
                            Just Moment...<i class="fa fa-circle-o-notch fa-spin" style="font-size:24px"></i>  Please Wait!
                        </p>
                    </div>
                </div>
            </div>
        </div>


    }
    else
    {
        <article class="B8D2gM _3E-II4 _3aQ08V">
            <h3 style="color: #218242; font-size: 16px; line-height: 10px; font-weight: 500;">
                It seems Room has been Sold Out.
            </h3>
        </article>
    }

}
<script type="text/javascript">
    $(document).ready(function () {
        $("a.selectroom").click(function () {
            document.getElementById("Token").value = (this).dataset.token;
            document.getElementById("RateCode").value = (this).dataset.ratecode;
            document.getElementById("RateId").value = (this).dataset.rateid;
            document.getElementById("RoomId").value = (this).dataset.roomid;
            //document.getElementById("HotelCode").value = (this).dataset.hotelcode;
            $("#DetailForm").submit();
        });
    });

    function AdditionalCharges(token, ratecode) {
        // alert('AdditionalCharges:- token - ' + token + ', ratecode- ' + ratecode);
        var jsondata = JSON.stringify({
            'Token': token,
            'RateCode': ratecode,
        });

        $.ajax({
            type: "POST",
            url: "/Hotel/AdditionalCharges",
            data: jsondata,
            contentType: "application/json; charset=utf-8",
            dataType: "html",
            success: function (response) {
                $('#additional').html('');
                $('#additional').html(response);
            },
            failure: function (response) {
                alert(response.responseText);
            },
            error: function (response) {
                alert(response.responseText);
            }
        });
    }

    function CancillationPolicy(token, ratecode) {
        // alert('CancillationPolicy:- token - ' + token + ', ratecode- ' + ratecode);
        var jsondata = JSON.stringify({
            'Token': token,
            'RateCode': ratecode,
        });

        $.ajax({
            type: "POST",
            url: "/Hotel/CancillationPolicy",
            data: jsondata,
            contentType: "application/json; charset=utf-8",
            dataType: "html",
            success: function (response) {
                $('#additional').html('');
                $('#additional').html(response);
            },
            failure: function (response) {
                alert(response.responseText);
            },
            error: function (response) {
                alert(response.responseText);
            }
        });
    }

</script>
